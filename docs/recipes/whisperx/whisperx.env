# WhisperX Docker Compose Environment Configuration
# Copy to whisperx.env and set your values.
# Never commit whisperx.env (it is gitignored).

# WhisperX Model Configuration
WHISPERX_MODEL=large-v2
WHISPERX_LANGUAGE=en
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_DEVICE=cpu
WHISPERX_DIARIZE=true

# Hugging Face Token (required for diarization/model access)
# Set in your local whisperx.env (never commit real tokens)
HF_TOKEN=

# WhisperX Service Configuration (when using compose)
WHISPERX_SERVICE_URL=http://whisperx:8000
WHISPERX_CONTAINER_NAME=transcriptx-whisperx

# Volume Mounts
WHISPERX_INPUT_DIR=/data/input
WHISPERX_OUTPUT_DIR=/data/output
WHISPERX_TRANSCRIPTX_OUTPUT_DIR=/data/transcriptx_output

# Local Paths (for docker exec commands)
LOCAL_DATA_DIR=./data
LOCAL_OUTPUTS_DIR=./outputs
LOCAL_TRANSCRIPTX_OUTPUT_DIR=./transcriptx_output

# Note: batch_size, min_speakers, max_speakers are WhisperX CLI flags only;
# pass them via docker exec when invoking WhisperX (e.g. --batch_size 16).
