# TranscriptX environment. Copy to .env and adjust as needed.
#
# Storage taxonomy:
#   Library dirs  = user-owned content (recordings, transcripts)
#   Working dirs  = app-managed state, outputs, cache
#   Config dirs   = user/app configuration and presets
#   Backup dirs   = archive / reproducibility artefacts
#
# All paths are stored internally as Path objects and serialized as
# strings at config/CLI/JSON boundaries.

# === Library dirs (user-owned, persistent, mountable, never auto-clean) ===
# TRANSCRIPTX_RECORDINGS_DIR=/path/to/recordings
# TRANSCRIPTX_TRANSCRIPTS_DIR=/path/to/transcripts

# === Working dirs (app-managed, persistent but partially reconstructable) ===
# TRANSCRIPTX_DATA_DIR=/path/to/data
# TRANSCRIPTX_OUTPUT_DIR=/path/to/outputs

# === Config (persistent, not safe to auto-delete) ===
# TRANSCRIPTX_CONFIG_DIR=/path/to/config
# TRANSCRIPTX_PROFILES_DIR=/path/to/profiles

# === Backup/archive (persistent, not auto-clean unless explicit) ===
# TRANSCRIPTX_WAV_BACKUP_DIR=/path/to/wav_backups
# (legacy: TRANSCRIPTX_WAV_STORAGE_DIR is accepted but deprecated)

# === Database (optional, overrides default SQLite at DATA_DIR/state/transcriptx.db) ===
# TRANSCRIPTX_DATABASE_URL=sqlite:///path/to/transcriptx.db
